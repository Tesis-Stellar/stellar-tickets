{
  "name": "stellar-tickets-backend",
  "version": "1.0.0",
  "description": "Web2.5 hybrid backend: Express proxy + Soroban indexer",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "npm run test:unit && npm run test:api",
    "test:unit": "VERCEL=1 RUN_INDEXER=false find src -name '*.test.ts' ! -name 'api.supertest.test.ts' ! -name '*.integration.test.ts' -print0 | xargs -0 node --import tsx --test",
    "test:api": "sh -c 'if [ -n \"$DATABASE_URL_TEST\" ]; then export DATABASE_URL=\"$DATABASE_URL_TEST\"; fi; VERCEL=1 RUN_INDEXER=false node --import tsx --test src/api.supertest.test.ts src/*.integration.test.ts'",
    "build": "tsc --noEmitOnError false || true",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "reconcile:onchain-db": "tsx scripts/reconcile-onchain-db.ts",
    "refresh:demo-events": "tsx scripts/refresh-demo-events.ts",
    "env:test": "bash scripts/switch-env.sh test",
    "env:prod": "bash scripts/switch-env.sh prod"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@stellar/stellar-sdk": "14.4.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.9.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
